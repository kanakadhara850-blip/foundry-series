rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
//
// Design: everyone (participants, no login) can READ event docs —
// that's how the QR-code flow works. Only authenticated admin users
// can WRITE. There's no public sign-up, so "authenticated" == "admin"
// here; if you later add other authenticated user types, replace
// `request.auth != null` with a custom-claim or allow-list check.

service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
