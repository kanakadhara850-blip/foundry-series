rules_version = '2';

// Deploy with: firebase deploy --only storage
//
// Datasets must be publicly downloadable (participants are not
// logged in), but only an authenticated admin can upload/overwrite
// them.

service firebase.storage {
  match /b/{bucket}/o {
    match /datasets/{eventId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024; // 200MB cap
    }
  }
}
